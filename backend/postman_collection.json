          ],
          "port": "5000",
          "path": [
            "api",
            "v1",
            "quote"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is success\", function () {",
              "    pm.response.to.have.jsonBody(\"status\", \"success\");",
              "});",
              "pm.test(\"Returns array of recommended plans\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.plans).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
